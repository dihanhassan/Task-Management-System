@{
    ViewData["Title"] = "Error";
    var statusCode = ViewData["StatusCode"]?.ToString() ?? "500";
    var message = ViewData["Message"]?.ToString() ?? "An unexpected error occurred.";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h1 class="display-1 text-danger fw-bold">@statusCode</h1>
            <h2 class="mb-3">Something went wrong</h2>
            <p class="text-muted mb-4">@message</p>
            <a href="/" class="btn btn-primary">Go to Home</a>
        </div>
    </div>
</div>
