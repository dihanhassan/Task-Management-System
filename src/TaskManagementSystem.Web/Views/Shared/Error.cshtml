@{
    ViewData["Title"] = "Error";
    var statusCode = ViewData["StatusCode"]?.ToString() ?? "500";
    var message = ViewData["Message"]?.ToString() ?? "An unexpected error occurred.";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-7 col-lg-6">
        <div class="tm-form-card text-center p-5 tm-fade-in">
            <div class="tm-empty-icon mx-auto" style="width:80px;height:80px;font-size:2.25rem;background:var(--tm-danger-50);color:var(--tm-danger)">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div style="font-size:3rem;font-weight:700;color:var(--tm-ink);line-height:1;margin-top:1rem">@statusCode</div>
            <h2 class="fw-bold mt-2 mb-2">Something went wrong</h2>
            <p class="text-muted mb-4">@message</p>
            <a href="/" class="tm-btn tm-btn-primary justify-content-center" style="display:inline-flex">
                <i class="bi bi-house"></i> Back to home
            </a>
        </div>
    </div>
</div>
