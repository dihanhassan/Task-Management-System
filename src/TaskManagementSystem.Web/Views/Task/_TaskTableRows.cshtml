@model X.PagedList.IPagedList<TaskRowViewModel>

@if (!Model.Any())
{
    <tr>
        <td colspan="5">
            <div class="tm-empty">
                <div class="tm-empty-icon"><i class="bi bi-inbox"></i></div>
                <div class="tm-empty-title">No tasks found</div>
                <div>Try adjusting your filters or create your first task to get started.</div>
            </div>
        </td>
    </tr>
}
else
{
    foreach (var task in Model)
    {
        var (badgeClass, priorityIcon) = task.Priority switch
        {
            Priority.High   => ("is-high",   "bi-arrow-up"),
            Priority.Medium => ("is-medium", "bi-dash"),
            _               => ("is-low",    "bi-arrow-down")
        };

        <tr class="@(task.IsCompleted ? "is-completed" : "")">
            <td>
                <button class="tm-toggle @(task.IsCompleted ? "is-checked" : "") toggle-status-btn"
                        data-task-id="@task.Id"
                        title="@(task.IsCompleted ? "Mark as pending" : "Mark as complete")">
                    <i class="bi bi-check-lg"></i>
                </button>
            </td>
            <td>
                <span class="task-title">
                    @if (task.IsCompleted)
                    {
                        <del>@task.Title</del>
                    }
                    else
                    {
                        @task.Title
                    }
                </span>
                @if (task.IsOverdue && !task.IsCompleted)
                {
                    <span class="tm-badge is-overdue ms-2">
                        <i class="bi bi-clock-history"></i> Overdue
                    </span>
                }
            </td>
            <td>
                @if (task.DueDate.HasValue)
                {
                    <span class="@(task.IsOverdue && !task.IsCompleted ? "text-danger fw-semibold" : "")">
                        <i class="bi bi-calendar3 me-1 text-muted"></i>@task.DueDate.Value.ToString("MMM dd, yyyy")
                    </span>
                }
                else
                {
                    <span class="text-muted">No due date</span>
                }
            </td>
            <td>
                <span class="tm-badge @badgeClass">
                    <i class="bi @priorityIcon"></i>@task.Priority
                </span>
            </td>
            <td style="text-align:right; padding-right:1.5rem">
                <div class="d-inline-flex gap-1">
                    <a asp-action="Edit" asp-route-id="@task.Id"
                       class="tm-btn-icon is-edit" title="Edit task">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <button class="tm-btn-icon is-danger delete-btn"
                            data-task-id="@task.Id"
                            data-task-title="@task.Title"
                            title="Delete task">
                        <i class="bi bi-trash"></i>
                    </button>
                    <form id="delete-form-@task.Id"
                          asp-action="Delete" asp-route-id="@task.Id"
                          method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </td>
        </tr>
    }
}
