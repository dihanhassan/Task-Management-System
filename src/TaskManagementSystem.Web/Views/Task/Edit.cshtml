@model TaskEditViewModel
@{
    ViewData["Title"] = "Edit Task";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <div class="d-flex align-items-center gap-2 mb-4">
            <a asp-action="Index" class="tm-btn-icon" title="Back to tasks">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h1 class="tm-page-title">Edit task</h1>
                <p class="tm-page-subtitle">Update the details below and save your changes.</p>
            </div>
        </div>

        <div class="tm-form-card">
            <div class="p-4 p-md-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="tm-flash is-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="tm-label"></label>
                        <input asp-for="Title" class="tm-input" maxlength="100" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="tm-label"></label>
                        <textarea asp-for="Description" class="tm-textarea" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="DueDate" class="tm-label"></label>
                            <input asp-for="DueDate" class="tm-input" type="date" />
                            <span asp-validation-for="DueDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Priority" class="tm-label"></label>
                            <select asp-for="Priority"
                                    asp-items="Html.GetEnumSelectList<Priority>()"
                                    class="tm-form-select">
                            </select>
                            <span asp-validation-for="Priority" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="tm-checkbox">
                            <input asp-for="IsCompleted" type="checkbox" />
                            <span>Mark as completed</span>
                        </label>
                    </div>

                    <div class="d-flex gap-2 justify-content-end pt-3" style="border-top:1px solid var(--tm-border); margin:0 -1.5rem -.5rem; padding-left:1.5rem; padding-right:1.5rem">
                        <a asp-action="Index" class="tm-btn tm-btn-ghost">Cancel</a>
                        <button type="submit" class="tm-btn tm-btn-primary">
                            <i class="bi bi-check-lg"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
