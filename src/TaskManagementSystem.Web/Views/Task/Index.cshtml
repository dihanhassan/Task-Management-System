@model TaskListViewModel
@using X.PagedList.Mvc.Core
@using X.PagedList
@{
    ViewData["Title"] = "My Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold mb-0"><i class="bi bi-list-task me-2 text-primary"></i>My Tasks</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Task
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-2 fw-bold text-primary">@Model.Dashboard.TotalTasks</div>
                <div class="text-muted small">Total Tasks</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-2 fw-bold text-success">@Model.Dashboard.CompletedTasks</div>
                <div class="text-muted small">Completed</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-2 fw-bold text-warning">@Model.Dashboard.PendingTasks</div>
                <div class="text-muted small">Pending</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-2 fw-bold text-danger">@Model.Dashboard.OverdueTasks</div>
                <div class="text-muted small">Overdue</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2 mb-3" id="filterForm">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" id="searchInput" name="searchTerm"
                           value="@Model.SearchTerm" class="form-control"
                           placeholder="Search tasks..." autocomplete="off" />
                </div>
            </div>
            <div class="col-md-3">
                <select name="filter" id="filterSelect" class="form-select">
                    @foreach (TaskFilter f in Enum.GetValues(typeof(TaskFilter)))
                    {
                        <option value="@((int)f)" selected="@(Model.ActiveFilter == f)">@f</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="sort" id="sortSelect" class="form-select">
                    <option value="@((int)TaskSort.DueDateAsc)"  selected="@(Model.ActiveSort == TaskSort.DueDateAsc)">Due Date (Asc)</option>
                    <option value="@((int)TaskSort.DueDateDesc)" selected="@(Model.ActiveSort == TaskSort.DueDateDesc)">Due Date (Desc)</option>
                    <option value="@((int)TaskSort.PriorityAsc)"  selected="@(Model.ActiveSort == TaskSort.PriorityAsc)">Priority (Low-High)</option>
                    <option value="@((int)TaskSort.PriorityDesc)" selected="@(Model.ActiveSort == TaskSort.PriorityDesc)">Priority (High-Low)</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-outline-secondary w-100" title="Apply filters">
                    <i class="bi bi-funnel"></i>
                </button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Title</th>
                        <th style="width:140px">Due Date</th>
                        <th style="width:110px">Priority</th>
                        <th style="width:90px" class="text-center">Status</th>
                        <th style="width:110px">Actions</th>
                    </tr>
                </thead>
                <tbody id="taskTableBody">
                    @await Html.PartialAsync("_TaskTableRows", Model.Tasks)
                </tbody>
            </table>
        </div>

        @if (Model.Tasks.PageCount > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-3">
                <small class="text-muted">
                    Showing @((Model.Tasks.PageNumber - 1) * Model.Tasks.PageSize + 1)
                    - @Math.Min(Model.Tasks.PageNumber * Model.Tasks.PageSize, Model.Tasks.TotalItemCount)
                    of @Model.Tasks.TotalItemCount tasks
                </small>
                <div>
                    @Html.PagedListPager(Model.Tasks, page => Url.Action("Index", new
                    {
                        page,
                        searchTerm = Model.SearchTerm,
                        filter = (int)Model.ActiveFilter,
                        sort = (int)Model.ActiveSort
                    }), new PagedListRenderOptions
                    {
                        LiElementClasses = new[] { "page-item" },
                        PageClasses = new[] { "page-link" },
                        UlElementClasses = new[] { "pagination pagination-sm mb-0" }
                    })
                </div>
            </div>
        }
    </div>
</div>
