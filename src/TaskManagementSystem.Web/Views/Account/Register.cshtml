@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account - Task Manager</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<div class="tm-auth-shell">
    <aside class="tm-auth-brand">
        <div class="tm-auth-brand-content">
            <div class="d-flex align-items-center gap-2">
                <span class="brand-mark" style="background:rgba(255,255,255,.2)"><i class="bi bi-check2-square"></i></span>
                <strong style="font-size:1.05rem">Task Manager</strong>
            </div>
            <h1>Start organizing your day in seconds.</h1>
            <p>Create your free account and gain a clear view of every task, deadline, and priority — all in one place.</p>

            <ul class="tm-auth-feature-list">
                <li><i class="bi bi-check-circle-fill"></i>No credit card required</li>
                <li><i class="bi bi-people-fill"></i>Each account is private and isolated</li>
                <li><i class="bi bi-phone-fill"></i>Works on mobile, tablet, and desktop</li>
                <li><i class="bi bi-rocket-takeoff-fill"></i>Up and running in under a minute</li>
            </ul>
        </div>
        <div style="position:relative; z-index:1; opacity:.75; font-size:.85rem">
            &copy; @DateTime.Now.Year Task Manager
        </div>
    </aside>

    <div class="tm-auth-form-wrap">
        <div class="tm-auth-card tm-fade-in">
            <div class="text-center mb-4">
                <span class="tm-auth-logo"><i class="bi bi-person-plus"></i></span>
                <h2 class="fw-bold mt-3 mb-1">Create your account</h2>
                <p class="text-muted mb-0">It only takes a moment to get started</p>
            </div>

            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="tm-flash is-danger mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="UserName" class="tm-label"></label>
                    <div class="tm-input-group">
                        <i class="bi bi-person"></i>
                        <input asp-for="UserName" class="tm-input" placeholder="Choose a username" autocomplete="username" />
                    </div>
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="tm-label"></label>
                    <div class="tm-input-group">
                        <i class="bi bi-envelope"></i>
                        <input asp-for="Email" class="tm-input" placeholder="you@example.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="tm-label"></label>
                    <div class="tm-input-group">
                        <i class="bi bi-lock"></i>
                        <input asp-for="Password" class="tm-input" placeholder="At least 6 characters" autocomplete="new-password" />
                        <button type="button" class="tm-password-toggle" tabindex="-1" aria-label="Show password">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div class="tm-help">Use 6+ characters with a mix of letters and numbers.</div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="tm-label"></label>
                    <div class="tm-input-group">
                        <i class="bi bi-lock-fill"></i>
                        <input asp-for="ConfirmPassword" class="tm-input" placeholder="Repeat your password" autocomplete="new-password" />
                        <button type="button" class="tm-password-toggle" tabindex="-1" aria-label="Show password">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="tm-btn tm-btn-primary w-100 justify-content-center">
                    <i class="bi bi-person-check"></i> Create Account
                </button>
            </form>

            <p class="text-center text-muted mt-4 mb-0" style="font-size:.9rem">
                Already have an account?
                <a asp-action="Login" class="text-decoration-none fw-semibold" style="color:var(--tm-primary)">Sign in</a>
            </p>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/task.js" asp-append-version="true"></script>
</body>
</html>
