@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - Task Manager</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<div class="tm-auth-shell">
    <aside class="tm-auth-brand">
        <div class="tm-auth-brand-content">
            <div class="d-flex align-items-center gap-2">
                <span class="brand-mark" style="background:rgba(255,255,255,.2)"><i class="bi bi-check2-square"></i></span>
                <strong style="font-size:1.05rem">Task Manager</strong>
            </div>
            <h1>Stay focused. Get more done.</h1>
            <p>A clean, fast way to organize your tasks, hit your deadlines, and track what matters most.</p>

            <ul class="tm-auth-feature-list">
                <li><i class="bi bi-lightning-charge-fill"></i>Real-time search and instant updates</li>
                <li><i class="bi bi-bar-chart-fill"></i>Live dashboard for total, pending, and overdue</li>
                <li><i class="bi bi-shield-lock-fill"></i>Secure account with private task isolation</li>
                <li><i class="bi bi-cloud-download-fill"></i>Export your tasks to CSV anytime</li>
            </ul>
        </div>
        <div style="position:relative; z-index:1; opacity:.75; font-size:.85rem">
            &copy; @DateTime.Now.Year Task Manager
        </div>
    </aside>

    <div class="tm-auth-form-wrap">
        <div class="tm-auth-card tm-fade-in">
            <div class="text-center mb-4">
                <span class="tm-auth-logo"><i class="bi bi-check2-square"></i></span>
                <h2 class="fw-bold mt-3 mb-1">Welcome back</h2>
                <p class="text-muted mb-0">Sign in to continue to your tasks</p>
            </div>

            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="tm-flash is-danger mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="tm-label"></label>
                    <div class="tm-input-group">
                        <i class="bi bi-envelope"></i>
                        <input asp-for="Email" class="tm-input" placeholder="you@example.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="tm-label"></label>
                    <div class="tm-input-group">
                        <i class="bi bi-lock"></i>
                        <input asp-for="Password" class="tm-input" placeholder="Enter your password" autocomplete="current-password" />
                        <button type="button" class="tm-password-toggle" tabindex="-1" aria-label="Show password">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <label class="tm-checkbox">
                        <input asp-for="RememberMe" type="checkbox" />
                        <span>Remember me</span>
                    </label>
                </div>

                <button type="submit" class="tm-btn tm-btn-primary w-100 justify-content-center">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                </button>
            </form>

            <p class="text-center text-muted mt-4 mb-0" style="font-size:.9rem">
                Don't have an account?
                <a asp-action="Register" class="text-decoration-none fw-semibold" style="color:var(--tm-primary)">Create one</a>
            </p>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/task.js" asp-append-version="true"></script>
</body>
</html>
